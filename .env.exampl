# =============================================================
# AnsysAgent 环境配置
# 复制此文件为 .env 并填入真实值
# =============================================================

# ------------------------------------------------------------
# LLM 提供商配置（推荐使用以下三个统一配置项）
# ------------------------------------------------------------

# 提供商标识，可选值：openrouter | deepseek | openai | qwen | gemini | glm | minimax
LLM_PROVIDER=

# 对应提供商的 API Key
LLM_API_KEY=

# 使用的模型名称（须属于所选提供商支持的模型）
# OpenRouter: openai/gpt-oss-120b:free | qwen/qwen3-next-80b-a3b-instruct:free
#             z-ai/glm-4.5-air:free | minimax/minimax-m2.5:free
# DeepSeek:   deepseek-chat | deepseek-reasoner
# OpenAI:     GPT-5.2 | gpt-4o
# Qwen:      qwen-max | qwen-plus | qwen-turbo | qwen-long
# Gemini:    gemini-3.0-flash
# GLM:       glm-4.6 | glm-4.7
# MiniMax:   minimax-m2
LLM_MODEL=openai/gpt-oss-120b:free

# ------------------------------------------------------------
# 回退链提供商 API Key（可选，覆盖内置默认值）
# 主提供商限速/余额不足时，自动按 OpenRouter → OpenAI → GLM → MiniMax 顺序回退
# ------------------------------------------------------------
# LLM_API_KEY_OPENROUTER=your_openrouter_api_key_here
# LLM_API_KEY_GLM=your_glm_api_key_here
# LLM_API_KEY_MINIMAX=your_minimax_api_key_here

# ------------------------------------------------------------
# 向后兼容（旧版配置，仍可使用，优先级低于 LLM_API_KEY）
# ------------------------------------------------------------
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
